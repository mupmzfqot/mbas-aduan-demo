{
  "name": "mbas-aduan-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src && htmlhint 'pages/**/*.html'",
    "lint:js": "eslint src",
    "lint:html": "htmlhint 'pages/**/*.html'",
    "format": "prettier --write 'src/**/*.{ts,js}' 'pages/**/*.html'",
    "format:check": "prettier --check 'src/**/*.{ts,js}' 'pages/**/*.html'",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "gh-pages": "^6.3.0",
    "glob": "^13.0.6",
    "htmlhint": "^1.9.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1"
  }
}
